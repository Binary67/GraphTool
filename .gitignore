# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.env

# User-uploaded markdown inputs and generated knowledge graphs
documents/**
!documents/
!documents/.gitkeep
!documents/markdown/
!documents/markdown/.gitkeep
!documents/pdfs/
!documents/pdfs/.gitkeep
!documents/recordings/
!documents/recordings/.gitkeep
data/
output/

# Per-run logs
logs/**
!logs/
!logs/.gitkeep
