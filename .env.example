AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_AGENT_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_FLAGSHIP_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_TRANSCRIPTION_DEPLOYMENT=gpt-4o-transcribe
AZURE_OPENAI_EMBEDDING_BATCH_SIZE=4
GRAPHTOOL_ENTITY_RESOLUTION_MIN_CANDIDATE_SIMILARITY=0.80
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USER_IDS=123456789
